# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.env.*

# ── Web app (web/) ────────────────────────────────────────────────────────────
web/node_modules/
web/.next/
web/out/
web/build/
web/next-env.d.ts
web/*.tsbuildinfo
web/package-lock.json

# ── Backend (backend/) ────────────────────────────────────────────────────────
# Database — never commit the live SQLite DB
backend/*.db
backend/app/*.db

# Vault — these are actual malware/suspicious files users uploaded
backend/app/vault/*
!backend/app/vault/.gitkeep

# Generated HTML forensic reports
backend/reports/

# Test/scratch files
backend/generate_test_files.py
backend/public_threat_test.txt
backend/test_files/

# ── Mobile app (mobile/) ─────────────────────────────────────────────────────
mobile/node_modules/
mobile/.expo/
mobile/android/build/
mobile/android/app/build/
mobile/android/.gradle/
mobile/android/local.properties
mobile/.next/

# ── Root-level test/scratch files ────────────────────────────────────────────
test_archive.zip
eicar.txt
*.zip
Test files apk/

# ── OS / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vercel
