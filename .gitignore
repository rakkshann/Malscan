# ── Python (backend/) ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.env.*
.pytest_cache/

# backend: never commit the live SQLite DB
backend/*.db
backend/app/*.db

# backend Vault — these are ACTUAL malware / suspicious files users uploaded
backend/app/vault/*
!backend/app/vault/.gitkeep

# backend: generated HTML forensic reports
backend/reports/

# backend: test/scratch helpers
backend/generate_test_files.py
backend/public_threat_test.txt
backend/test_files/

# ── Frontend (frontend/) ───────────────────────────────────────────────────────
# frontend/ also has its own .gitignore (Next.js defaults); these are a
# belt-and-suspenders backstop for build output and dependencies.
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/next-env.d.ts
frontend/*.tsbuildinfo
frontend/package-lock.json

# ── Root-level test/scratch files ──────────────────────────────────────────────
test_archive.zip
eicar.txt
*.zip
Test files apk/

# ── Local-only notes (personal study/audit notes, not shipped) ─────────────────
CODEBASE_WALKTHROUGH.md
AUDIT_REPORT.md

# ── OS / IDE ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vercel
