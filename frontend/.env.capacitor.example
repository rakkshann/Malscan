# Copy to .env.capacitor (git-ignored) — consumed by `npm run build:capacitor`.
# The real file MUST exist, or the static export (out/) won't run and
# `npx cap sync android` fails with "Could not find the web assets directory".

# Switches next.config.ts to `output: "export"` (produces out/) instead of a server build.
BUILD_TARGET=capacitor

# Default backend URL baked into the APK. Set this to the cloud backend so the
# app works anywhere with no laptop running:
#   NEXT_PUBLIC_API_BASE_URL=https://<your-app>.onrender.com
# Leave blank to set it at runtime via the in-app Settings screen instead.
NEXT_PUBLIC_API_BASE_URL=

# GitHub API URL (not the gist.githubusercontent.com "raw" URL — that's CDN-cached
# and can lag several minutes behind actual content) for the update-manifest Gist:
#   https://api.github.com/gists/<gistId>
# Checked on every app launch to detect OTA/native updates. Leave blank to disable update checks.
NEXT_PUBLIC_VERSION_MANIFEST_URL=
